  "description": "High-performance, runtime-agnostic GitHub GraphQL fetcher with SWR caching.",
  "keywords": [
    "bun",
    "cache",
    "edge",
    "fetch",
    "github",
    "graphql",
    "ofetch",
    "swr",
    "typescript",
    "unstorage"
  ],
  "homepage": "https://github.com/shiinasaku/kaito#readme",
  "bugs": {
    "url": "https://github.com/shiinasaku/kaito/issues"
  },
  "license": "MIT",
  "author": "Saku Shiina <sakushiina@proton.me>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shiinasaku/kaito.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "types": "./dist/index.d.ts",
  "exports": {
