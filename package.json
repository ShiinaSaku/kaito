  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@typescript/native-preview": "7.0.0-dev.20260409.1",
    "bumpp": "^11.0.1",
    "dotenv": "^17.4.1",
    "typescript": "^6.0.2",
    "vite-plus": "^0.1.16"
  },
  "packageManager": "pnpm@10.33.0"
